# Root .env — docker compose reads this file for variable substitution.
# Copy to .env and fill in values before running docker compose on a VPS.
# Do NOT commit .env — it stays gitignored.

# Your public domain (no https:// prefix, no trailing slash).
# Caddy will obtain Let's Encrypt certs for DOMAIN and api.DOMAIN.
DOMAIN=protonfix.example.com

# Activate the production overlay automatically so plain `docker compose`
# commands (including scripts/update.sh) pick up both files.
COMPOSE_FILE=docker-compose.yml:docker-compose.prod.yml
