# OpenAI API key — required for the AI fallback analyser.
# The deterministic engine works without it; AI is only invoked when
# no fingerprint matches the uploaded log.
OPENAI_API_KEY=sk-...your-key-here...

# Optional: directory for persistent data (history.db, uploads/, stats/).
# Defaults to the current working directory.
# In Docker this is set to /data in the Dockerfile; override here only
# if you want data stored somewhere other than the named volume default.
# PROTONFIX_DATA_DIR=/data

# Comma-separated list of origins allowed by CORS.
# Default "*" is for local development; set your real frontend origin
# in production, e.g. https://protonfix.example.com
# PROTONFIX_ALLOWED_ORIGINS=*

# Shared secret protecting the /admin endpoints. If empty, admin routes
# are open — set this before any public deployment.
# PROTONFIX_ADMIN_TOKEN=
