# URL of the ProtonFix backend API as seen from the user's browser.
# This value is baked into the client bundle at Next.js build time.
#
# Local dev:       http://127.0.0.1:8000  (current default in .env.local)
# Docker compose:  http://localhost:8000   (default in docker-compose.yml build arg)
# Production:      https://api.your-domain.com
NEXT_PUBLIC_API_URL=http://localhost:8000
